# each a summary df of the mean FC for those replicates and keep the same FC value for the rest
fc_summary <- master_df_with_NAIVE_delta_delta_CT_for_plotting %>%
group_by(target_gene, target_name, target_type, KD_of_interest, sample_name, p.value,sig_label) %>%
summarise(
mean_fc = mean(foldChange),
sd_fc = ifelse(n() > 1, sd(foldChange), NA_real_),  # only compute SD if more than 1 value
.groups = "drop"
) %>%
mutate(regulation = if_else(mean_fc > 1, "KD_up", "Naive_up"))
View(fc_summary)
