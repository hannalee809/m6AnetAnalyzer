qpcr_dir <- "/Users/hannalee2002/Partners HealthCare Dropbox/Hanna Lee/Ponnolu.p Team Folder/Cotranscfections_qpcr/20260108_KF_single_transfections_KD_validation"
# List all .xls files in the directory
qpcr_files <- list.files(qpcr_dir, pattern = "\\.xls$", full.names = TRUE)
qpcr_files
process_qpcr_file <- function(file_path) {
# Extract run_id from file name
run_id <- str_remove(basename(file_path), "\\.xls$|\\.xlsx$")
# Read the file, skip metadata
data <- read_xls(file_path, skip = 7)  # or read_xlsx for .xlsx files
# Optional: remove completely empty columns
data <- data %>% dplyr::select(where(~ !all(is.na(.))))
# Add run_id as a new column
data$run_id <- run_id
# Filter and reshape
data_filt <- data %>%
filter(`Sample Name` != "NTC") %>%
dplyr::select(
run_id = run_id,
sample_name = `Sample Name`,
target_name = `Target Name`,
reporter = Reporter,
CT = `Cт`,
avg_CT = `Cт Mean`,
std_CT = `Cт SD`
) %>%
group_by(sample_name, target_name) %>%
mutate(rep = row_number()) %>%
ungroup() %>%
pivot_wider(
names_from = rep,
values_from = CT,
names_prefix = "Ct_rep"
)
return(data_filt)
}
# Process all files and rowbind into one master dataframe
master_df_single_transfection <- map_df(qpcr_files, process_qpcr_file)
View(master_df_single_transfection)
#################
#################
#################
################# CALCULATE DELTA CT
# Extract GAPDH values into new DF
GAPDH_qpcr_df_single <- master_df_single_transfection %>%
filter(target_name == "GAPDH") %>%
dplyr::select(
run_id,
sample_name,
GAPDH_avg_CT = avg_CT
)
# Merge with master df
master_df_single_transfection <- merge(master_df_single_transfection, GAPDH_qpcr_df_single, by= c("run_id", "sample_name"))
View(master_df_single_transfection)
# filter GAPDH row (redundant), calculate delta CT, and select necessary columns
master_df_single_transfection <- master_df_single_transfection %>%
filter(target_name != "GAPDH") %>%
mutate(EXP_deltaCT = avg_CT - GAPDH_avg_CT) %>%
dplyr::select(
run_id,
sample_name,
target_name,
EXP_avg_CT = avg_CT,
GAPDH_avg_CT,
EXP_deltaCT
)
View(master_df_single_transfection)
