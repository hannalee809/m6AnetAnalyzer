## Plot with mean FC
plot_list <- fc_summary %>%
group_split(target_gene) %>%
lapply(function(df_gene) {
ggplot(df_gene, aes(x = KD_of_interest, y = mean_fc, fill = regulation)) +
geom_col(width = 0.7) +
geom_text(
aes(label = sig_label),
y = df_gene$mean_fc + .2,
size = 5,
na.rm = TRUE
) +
geom_errorbar(aes(ymin = mean_fc - sd_fc, ymax = mean_fc + sd_fc),
width = 0.2, na.rm = TRUE) +
facet_wrap(~ target_name) +
geom_hline(yintercept = 1, linetype = "dashed") +
coord_cartesian(ylim = c(0,3)) +
scale_fill_manual(
values = c("KD_up" = "#547792", "Naive_up" = "#ED985F"),
name = "Regulation"
) +
theme_bw() +
theme(axis.text.x = element_text(angle = 45, hjust = 1, vjust = 1)) +
labs(
title = unique(df_gene$target_gene),
x = "Knockdown condition",
y = "Fold change vs naïve (2^-ΔΔCT)"
)
ggsave(
filename = paste0(gene, "_qPCR_MEAN_foldChange_vs_Naive.pdf"),
plot = p,
width = max(6, n_facets * 1.5),
height = 4
)
})
